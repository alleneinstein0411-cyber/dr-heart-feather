---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HualienHero from '../assets/home/hualien-fields-birds-hero.png';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
const base = import.meta.env.BASE_URL;

const paths = [
	{
		title: '血脂筆記',
		text: '膽固醇、三酸甘油脂、飲食、藥物與抽血追蹤。',
	},
	{
		title: '血壓日常',
		text: '高血壓、居家量測、鹽分、運動與長期照護。',
	},
	{
		title: '冠心病故事',
		text: '胸悶、心絞痛、心肌梗塞、心導管與支架前後的理解。',
	},
	{
		title: '心肺好好過',
		text: '運動、喘、心肺耐力、睡眠、體重與代謝健康。',
	},
	{
		title: '診間心情',
		text: '病人的害怕與猶豫、家屬照顧、治療選擇與個案故事。',
	},
];
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero" aria-labelledby="hero-title">
				<Image class="hero-bg" src={HualienHero} alt="" loading="eager" widths={[960, 1400, 1920]} sizes="100vw" />
				<div class="hero-shade" aria-hidden="true"></div>
				<div class="hero-inner">
					<div class="hero-copy">
						<p class="eyebrow">Patient Education · Cardiology Notes</p>
						<h1 id="hero-title">張醫師心羽診間</h1>
						<p class="hero-lede">
							用診間故事，陪民眾看懂心臟病、心導管與治療選擇。像花蓮的田和天空一樣，把複雜的事慢慢攤開，讓心裡有地方可以呼吸。
						</p>
						<div class="button-row">
							<a class="button" href={`${base}blog/`}>閱讀文章</a>
						</div>
					</div>
				</div>
			</section>

			<section class="section" aria-labelledby="paths-title">
				<div class="section-header">
					<div>
						<p class="eyebrow">Topics</p>
						<h2 id="paths-title">心羽分類</h2>
					</div>
				</div>
				<div class="card-grid">
					{
						paths.map((path) => (
							<article class="card">
								<h3>{path.title}</h3>
								<p>{path.text}</p>
							</article>
						))
					}
				</div>
			</section>

			<section class="section" aria-labelledby="latest-title">
				<div class="section-header">
					<div>
						<p class="eyebrow">Recent</p>
						<h2 id="latest-title">最新文章</h2>
					</div>
					<a href={`${base}blog/`}>全部文章</a>
				</div>
				<div class="post-list">
					{
						posts.map((post) => (
							<a class="post-row" href={`${base}blog/${post.id}/`}>
								<span class="tag">{post.data.category ?? '衛教文章'}</span>
								<span class="post-title">{post.data.title}</span>
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		position: relative;
		display: grid;
		align-items: center;
		width: 100vw;
		min-height: calc(100vh - 112px);
		margin-left: calc(50% - 50vw);
		margin-top: -56px;
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.hero-shade {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(90deg, rgba(255, 253, 248, 0.88) 0%, rgba(255, 253, 248, 0.66) 38%, rgba(255, 253, 248, 0.08) 72%),
			linear-gradient(180deg, rgba(255, 253, 248, 0.12), rgba(38, 50, 56, 0.18));
	}

	.hero-inner {
		position: relative;
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 88px 0 96px;
	}

	.hero-copy {
		max-width: 660px;
	}

	.hero h1 {
		margin-bottom: 1rem;
		font-size: 4.8rem;
		text-wrap: balance;
	}

	.hero-lede {
		max-width: 620px;
		color: #344540;
		font-size: 1.2rem;
		line-height: 1.9;
	}

	.hero .button {
		box-shadow: 0 14px 34px rgba(38, 50, 56, 0.16);
	}


	.post-list {
		border-top: 1px solid var(--line);
	}

	.post-row {
		display: grid;
		grid-template-columns: 128px 1fr 150px;
		align-items: center;
		gap: 18px;
		padding: 20px 0;
		border-bottom: 1px solid var(--line);
		color: var(--ink);
		text-decoration: none;
	}

	.post-row:hover .post-title {
		color: var(--teal-deep);
	}

	.post-title {
		font-weight: 700;
	}

	.post-date {
		color: var(--muted);
		font-size: 0.92rem;
		text-align: right;
	}

	@media (max-width: 860px) {
		.hero {
			min-height: auto;
			margin-top: -34px;
		}

		.hero h1 {
			font-size: 3rem;
		}

		.hero-lede {
			font-size: 1.06rem;
		}

		.hero-shade {
			background:
				linear-gradient(180deg, rgba(255, 253, 248, 0.88), rgba(255, 253, 248, 0.58) 62%, rgba(38, 50, 56, 0.12)),
				linear-gradient(90deg, rgba(255, 253, 248, 0.5), transparent);
		}

		.hero-inner {
			padding: 72px 0 82px;
		}

		.post-row {
			grid-template-columns: 1fr;
			gap: 8px;
		}

		.post-date {
			text-align: left;
		}
	}
</style>
