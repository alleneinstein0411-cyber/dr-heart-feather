---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={`文章｜${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="blog-page">
			<section class="blog-hero">
				<p class="eyebrow">Articles</p>
				<h1>文章</h1>
				<p>血脂、血壓、冠心病、心肺生活與診間故事，都放在這裡。</p>
			</section>

			<section class="article-list" aria-label="文章列表">
				{
					posts.map((post) => (
						<a class="article-card" href={`${base}blog/${post.id}/`}>
							<div>
								<span class="tag">{post.data.category ?? '衛教文章'}</span>
								<h2>{post.data.title}</h2>
								<p>{post.data.description}</p>
							</div>
							<div class="meta">
								<FormattedDate date={post.data.pubDate} />
								{post.data.sourceLevel && <span>{post.data.sourceLevel}</span>}
							</div>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-page {
		max-width: 980px;
	}

	.blog-hero {
		padding: 48px 0 30px;
	}

	.blog-hero h1 {
		font-size: 3rem;
	}

	.blog-hero p:not(.eyebrow) {
		max-width: 680px;
		color: var(--muted);
	}

	.article-list {
		display: grid;
		gap: 16px;
	}

	.article-card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 180px;
		gap: 20px;
		padding: 24px 0;
		border-top: 1px solid var(--line);
		color: var(--ink);
		text-decoration: none;
	}

	.article-card:last-child {
		border-bottom: 1px solid var(--line);
	}

	.article-card h2 {
		margin-top: 12px;
		font-size: 1.45rem;
	}

	.article-card p {
		max-width: 680px;
		color: var(--muted);
	}

	.article-card:hover h2 {
		color: var(--teal-deep);
	}

	.meta {
		display: grid;
		align-content: start;
		gap: 6px;
		color: var(--muted);
		font-size: 0.9rem;
		text-align: right;
	}

	@media (max-width: 760px) {
		.blog-hero h1 {
			font-size: 2.4rem;
		}

		.article-card {
			grid-template-columns: 1fr;
		}

		.meta {
			text-align: left;
		}
	}
</style>
